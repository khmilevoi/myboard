{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ES2023", "ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../shared/*"],
      "@widgets/*": ["../widgets/*"],
      "react": ["./node_modules/react"],
      "react/jsx-runtime": ["./node_modules/react/jsx-runtime"],
      "react/jsx-dev-runtime": ["./node_modules/react/jsx-dev-runtime"],
      "react-dom": ["./node_modules/react-dom"],
      "@reatom/core": ["./node_modules/@reatom/core"],
      "@testing-library/react": ["./node_modules/@testing-library/react"],
      "zod": ["./node_modules/zod"],
      "lucide-react": ["./node_modules/lucide-react"]
    }
  },
  "include": ["src", "../widgets", "tests"]
}
