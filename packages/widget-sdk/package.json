{
  "name": "widget-sdk",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "vite-build-exit": "./bin/vite-build.mjs"
  },
  "type": "module",
  "imports": {
    "#lib/utils": "./src/lib/utils.ts",
    "#lib/*": "./src/lib/*.ts",
    "#components/*": "./src/ui/*.tsx",
    "#hooks/*": "./src/hooks/*.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./lib/utils": "./src/lib/utils.ts",
    "./ui/*": "./src/ui/*.tsx",
    "./reatom/*": "./src/reatom/*.ts",
    "./define-widget-client": "./src/define-widget-client.ts",
    "./vite": "./src/vite/index.ts",
    "./test-setup": "./src/test/widget-setup.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@reatom/core": "catalog:",
    "@reatom/react": "catalog:",
    "clsx": "catalog:",
    "errore": "catalog:",
    "lucide-react": "catalog:",
    "radix-ui": "catalog:",
    "react": "catalog:",
    "tailwind-merge": "catalog:",
    "widget-runtime": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@module-federation/vite": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "fake-indexeddb": "catalog:",
    "jsdom": "catalog:",
    "react-dom": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
