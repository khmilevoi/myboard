{
  "name": "widget-sdk",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "vite-build-exit": "./bin/vite-build.mjs"
  },
  "type": "module",
  "imports": {
    "#lib/utils": "./src/lib/utils.ts",
    "#lib/*": "./src/lib/*.ts",
    "#components/*": "./src/ui/*.tsx",
    "#hooks/*": "./src/hooks/*.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./lib/utils": "./src/lib/utils.ts",
    "./ui/*": "./src/ui/*.tsx",
    "./reatom/*": "./src/reatom/*.ts",
    "./define-widget-client": "./src/define-widget-client.ts",
    "./vite": "./src/vite/index.ts",
    "./test-setup": "./src/test/widget-setup.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@reatom/core": "catalog:",
    "@reatom/react": "catalog:",
    "clsx": "^2.1.1",
    "errore": "catalog:",
    "lucide-react": "catalog:",
    "radix-ui": "^1.6.0",
    "react": "catalog:",
    "tailwind-merge": "^3.6.0",
    "widget-runtime": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.16.12",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "@vitejs/plugin-react": "^6.0.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "react-dom": "catalog:",
    "vite": "^8.1.2",
    "vitest": "catalog:"
  }
}
