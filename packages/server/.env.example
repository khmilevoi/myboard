# Storage
VALKEY_URL=redis://localhost:6379
PORT=8787

# Browser automation gateway (optional; defaults shown)
# BROWSER_AUTOMATION_URL=http://browser-automation:8788
# BROWSER_AUTOMATION_TIMEOUT_MS=100000

# --- WebAuthn / device-invite auth gate ---
# Relying Party ID: the domain WebAuthn credentials are scoped to (no scheme/port).
RP_ID=localhost
# Human-readable name shown by the platform authenticator UI.
RP_NAME=MyBoard
# Public URL of the app (used to build invite/add-device links).
PUBLIC_APP_URL=http://localhost:4173
# Origin WebAuthn ceremonies must match exactly (scheme+host+port). Drives
# secureCookies: https: origins get __Host- cookies, http: origins (dev/e2e) don't.
EXPECTED_ORIGIN=http://localhost:4173
# Session cookie base name; __Host- prefix is added/dropped automatically
# based on EXPECTED_ORIGIN's scheme.
SESSION_COOKIE_NAME=__Host-mb_session
# Session lifetimes: sliding renewal window and absolute cap. Accepts
# d/h/m/s suffixes (e.g. 30d, 12h, 5m, 30s).
SESSION_TTL_SLIDING=30d
SESSION_TTL_ABSOLUTE=90d
# Set to 1 only behind a trusted reverse proxy (e.g. Cloudflare Tunnel) that
# guarantees CF-Connecting-IP; leave 0 to ignore it and fall back to the
# raw socket address.
TRUST_CF_CONNECTING_IP=0
